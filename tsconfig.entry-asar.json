{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2017",
    "lib": ["es2017"],
    "sourceMap": true,
    "strict": true,
    "rootDir": "entry-asar",
    "outDir": "entry-asar",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "declaration": false,
    "ignoreDeprecations": "6.0"
  },
  "include": ["entry-asar"],
  "exclude": []
}
